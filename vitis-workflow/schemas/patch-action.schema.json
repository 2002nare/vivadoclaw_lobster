{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VitisHLSPatchAction",
  "description": "A single patch action to apply to a Vitis HLS project",
  "type": "object",
  "required": ["action", "params", "reason"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "add_source",
        "remove_source",
        "add_testbench",
        "remove_testbench",
        "set_top",
        "set_part",
        "set_clock"
      ]
    },
    "params": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "function_name": { "type": "string" },
        "part": { "type": "string" },
        "clock_period_ns": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}

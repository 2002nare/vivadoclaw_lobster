{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VivadoPatchAction",
  "description": "A single patch action to apply to a Vivado project",
  "type": "object",
  "required": ["action", "params", "reason"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "add_source",
        "remove_source",
        "add_constraint",
        "remove_constraint",
        "set_top",
        "set_property"
      ]
    },
    "params": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["verilog", "systemverilog", "vhdl", "xdc"]
        },
        "library": { "type": "string" },
        "module_name": { "type": "string" },
        "property_name": { "type": "string" },
        "property_value": { "type": "string" },
        "object": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}

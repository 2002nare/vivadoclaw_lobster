{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VitisHLSExportReview",
  "description": "Structured review result from llm-task for Vitis HLS export",
  "type": "object",
  "required": ["status", "issues", "patches", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "warning"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "category": {
            "type": "string",
            "enum": ["export_error", "packaging", "config", "general"]
          },
          "message": { "type": "string" },
          "related_file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "params", "reason"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["set_top"]
          },
          "params": {
            "type": "object",
            "properties": {
              "function_name": { "type": "string" }
            },
            "additionalProperties": false
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" }
  },
  "additionalProperties": false
}
